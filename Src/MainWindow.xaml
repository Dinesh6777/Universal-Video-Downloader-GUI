<Window x:Class="YtDlpDownloader.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Universal Video Downloader" 
        Height="700" Width="850" 
        Background="#F4F4F9" 
        WindowStartupLocation="CenterScreen"
        Icon="appicon.ico"
        Loaded="Window_Loaded">
    
    <Grid Margin="25">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/> <!-- Header -->
            <RowDefinition Height="Auto"/> <!-- Batch Input -->
            <RowDefinition Height="Auto"/> <!-- Controls -->
            <RowDefinition Height="*"/>    <!-- Logs -->
            <RowDefinition Height="Auto"/> <!-- Footer -->
        </Grid.RowDefinitions>

        <!-- Header Section -->
        <StackPanel Grid.Row="0" Margin="0,0,0,25">
            <TextBlock Text="Universal Video Downloader" FontSize="28" FontWeight="Bold" Foreground="#222"/>
            <TextBlock Text="Supports Youtube, Facebook, and more - Powered by yt-dlp" 
                       Foreground="#666" FontSize="14" Margin="0,2,0,0"/>
            <TextBlock x:Name="BatchStatus" Text="Ready to download" Foreground="#0078D7" FontSize="12" Margin="0,5,0,0" FontWeight="SemiBold"/>
        </StackPanel>

        <!-- Multi-URL Input Section -->
        <StackPanel Grid.Row="1" Margin="0,0,0,20">
            <TextBlock Text="Enter Video URLs(one per line) or Playlist URL:" 
                       FontWeight="SemiBold" Margin="0,0,0,8" Foreground="#444"/>
            
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <Grid Grid.Column="0">
                    <!-- Placeholder Text -->
                    <TextBlock x:Name="PlaceholderText" Margin="10" Foreground="#AAA" IsHitTestVisible="False" VerticalAlignment="Top">
                        https://www.youtube.com/watch?v=BLelz0cH7M8&#x0a;https://www.youtube.com/watch?v=jcHvPmTTirU&#x0a;https://www.youtube.com/watch?v=eGGUmoxvdAM
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <!-- Triggers visibility when UrlInput is empty -->
                                    <DataTrigger Binding="{Binding Text, ElementName=UrlInput}" Value="">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>

                    <TextBox x:Name="UrlInput" Height="120" AcceptsReturn="True" TextWrapping="Wrap" 
                             VerticalScrollBarVisibility="Auto" Padding="10" FontSize="13" BorderBrush="#CCC"/>
                </Grid>

                <Button Grid.Column="1" Content="Clear" Click="BtnClear_Click" 
                        Width="80" Margin="10,0,0,0" Height="120" 
                        Background="#E0E0E0" VerticalAlignment="Stretch"/>
            </Grid>
        </StackPanel>

        <!-- Quality & Action Buttons -->
        <Grid Grid.Row="2" Margin="0,0,0,20">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            
            <StackPanel Orientation="Horizontal" Grid.Column="0">
                <TextBlock Text="Quality:" VerticalAlignment="Center" Margin="0,0,12,0" Foreground="#444"/>
                <ComboBox x:Name="QualityCombo" Width="190" Height="35" VerticalContentAlignment="Center">
                    <ComboBoxItem Content="Best (Highest Available)" Tag="best" IsSelected="True"/>
                    <ComboBoxItem Content="8K (4320p)" Tag="4320"/>
                    <ComboBoxItem Content="4K (2160p)" Tag="2160"/>
                    <ComboBoxItem Content="2K (1440p)" Tag="1440"/>
                    <ComboBoxItem Content="1080p" Tag="1080"/>
                    <ComboBoxItem Content="720p" Tag="720"/>
                    <ComboBoxItem Content="480p" Tag="480"/>
                    <ComboBoxItem Content="360p" Tag="360"/>
                    <ComboBoxItem Content="MP3 (Audio Only)" Tag="mp3"/>
                </ComboBox>
            </StackPanel>

            <Grid Grid.Column="3">
                <Button x:Name="BtnDownload" Content="Download now" Click="BtnDownload_Click" Width="160" Height="40" Background="#0078D7" Foreground="White" FontWeight="Bold"/>
                <Button x:Name="BtnStop" Content="Stop Batch" Click="BtnStop_Click" Width="160" Height="40" Background="#D32F2F" Foreground="White" FontWeight="Bold" Visibility="Collapsed"/>
            </Grid>
        </Grid>

        <!-- Logs & Progress -->
        <GroupBox Grid.Row="3" Header="Log &amp; Progress" Padding="12" Background="White">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/> <!-- FIXED: Corrected height attribute -->
                </Grid.RowDefinitions>
                <ProgressBar x:Name="PrgBar" Height="12" Margin="0,5,0,8" Minimum="0" Maximum="100" Foreground="#28A745"/>
                <TextBlock x:Name="TxtStatus" Text="Ready" Margin="2,0,0,10" Foreground="#666" FontSize="12" FontStyle="Italic"/>
                <ListBox x:Name="LstLog" Grid.Row="2" Background="#F8F9FA" FontSize="11" FontFamily="Consolas"/>
            </Grid>
        </GroupBox>

        <!-- Footer -->
        <StackPanel Grid.Row="4" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,15,0,0">
            <Button x:Name="BtnOpenFolder" Content="📂 Open Downloads Folder" Click="BtnOpenFolder_Click" Padding="20,8" Background="#6C757D" Foreground="White" Visibility="Collapsed"/>
        </StackPanel>
    </Grid>
</Window>