<Window x:Class="YtDlpDownloader.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Universal Video Downloader" 
        Height="650" Width="800" 
        Background="#F4F4F9" 
        WindowStartupLocation="CenterScreen"
        Icon="appicon.ico"
        Loaded="Window_Loaded">
    
    <Grid Margin="25">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/> <!-- Header -->
            <RowDefinition Height="Auto"/> <!-- Input -->
            <RowDefinition Height="Auto"/> <!-- Controls -->
            <RowDefinition Height="*"/>    <!-- Progress/Logs -->
            <RowDefinition Height="Auto"/> <!-- Footer -->
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Margin="0,0,0,25">
            <TextBlock Text="Universal Video Downloader" FontSize="28" FontWeight="Bold" Foreground="#222"/>
            <TextBlock Text="Supports YouTube, Facebook, and more - Powered by yt-dlp" Foreground="#666" FontSize="14" Margin="0,2,0,0"/>
        </StackPanel>

        <!-- URL Input -->
        <StackPanel Grid.Row="1" Margin="0,0,0,20">
            <TextBlock Text="Video or Playlist URL:" FontWeight="SemiBold" Margin="0,0,0,8" Foreground="#444"/>
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBox x:Name="UrlInput" Padding="10" FontSize="14" VerticalContentAlignment="Center" BorderBrush="#CCC"/>
                <Button Grid.Column="1" Content="Clear" Click="BtnClear_Click" Margin="8,0,0,0" Padding="15,0" Background="#E0E0E0"/>
            </Grid>
        </StackPanel>

        <!-- Quality & Action Buttons -->
        <Grid Grid.Row="2" Margin="0,0,0,20">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            
            <StackPanel Orientation="Horizontal" Grid.Column="0">
                <TextBlock Text="Quality:" VerticalAlignment="Center" Margin="0,0,12,0" Foreground="#444"/>
                <ComboBox x:Name="QualityCombo" Width="130" Height="35" VerticalContentAlignment="Center">
                    <ComboBoxItem Content="360p" Tag="360"/>
                    <ComboBoxItem Content="480p" Tag="480"/>
                    <ComboBoxItem Content="720p" Tag="720" IsSelected="True"/>
                    <ComboBoxItem Content="1080p" Tag="1080"/>
                </ComboBox>
            </StackPanel>

            <Grid Grid.Column="3">
                <Button x:Name="BtnDownload" Content="Download Now" Click="BtnDownload_Click" Width="160" Height="40" Background="#0078D7" Foreground="White" FontWeight="Bold" FontSize="14"/>
                <Button x:Name="BtnStop" Content="Stop Download" Click="BtnStop_Click" Width="160" Height="40" Background="#D32F2F" Foreground="White" FontWeight="Bold" FontSize="14" Visibility="Collapsed"/>
            </Grid>
        </Grid>

        <!-- Progress/Logs -->
        <GroupBox Grid.Row="3" Header="Status &amp; Progress" Padding="12" Background="White">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <ProgressBar x:Name="PrgBar" Height="12" Margin="0,5,0,8" Minimum="0" Maximum="100" Foreground="#28A745"/>
                <TextBlock x:Name="TxtStatus" Text="Ready" Margin="2,0,0,10" Foreground="#666" FontSize="12" FontStyle="Italic"/>
                <ListBox x:Name="LstLog" Grid.Row="2" Background="#F8F9FA" BorderBrush="#EEE" FontSize="11" FontFamily="Consolas"/>
            </Grid>
        </GroupBox>

        <!-- Footer -->
        <StackPanel Grid.Row="4" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,20,0,0">
            <Button x:Name="BtnOpenFolder" Content="📂 Open Downloads Folder" Click="BtnOpenFolder_Click" Padding="20,8" Background="#6C757D" Foreground="White" Visibility="Collapsed"/>
        </StackPanel>
    </Grid>
</Window>
